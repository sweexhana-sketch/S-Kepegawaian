# Environment Variables untuk S-Kepegawaian (Vercel)

# String koneksi database Neon Postgres (Dapatkan dari dashboard Neon)
DATABASE_URL="postgres://user:password@endpoint.neon.tech/dbname"

# Secret untuk enkripsi session (Generate random string, min 32 chars)
# Bisa pakai hasil dari `openssl rand -base64 32` di terminal
AUTH_SECRET="your-random-secret-key-here"

# ANYTHING_PROJECT_TOKEN 
# (Biasanya tidak perlu diganti jika tidak menggunakan backend Anythings)
ANYTHING_PROJECT_TOKEN=""
