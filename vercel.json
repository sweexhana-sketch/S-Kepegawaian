{
  "version": 2,
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "^/assets/(.+)$", "dest": "/build/client/assets/$1" },
    { "src": "^/(.*)$", "dest": "/api/index" }
  ]
}

